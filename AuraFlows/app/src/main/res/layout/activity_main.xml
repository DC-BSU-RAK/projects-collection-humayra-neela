<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/aura_flow_bg"
    tools:context=".MainActivity">

    <!-- Welcome Screen -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/welcomeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="visible">

        <ImageButton
            android:id="@+id/infoButton"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_margin="24dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/info_description"
            android:src="@android:drawable/ic_menu_info_details"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/welcomeTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/welcome_user"
                android:textColor="@color/white"
                android:textSize="48sp"
                android:textStyle="bold"
                android:shadowColor="#80000000"
                android:shadowDx="2"
                android:shadowDy="2"
                android:shadowRadius="4" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hope_enjoy"
                android:textColor="@color/white"
                android:textSize="20sp"
                android:alpha="0.9" />
        </LinearLayout>

        <Button
            android:id="@+id/getStartedButton"
            android:layout_width="220dp"
            android:layout_height="64dp"
            android:layout_marginBottom="64dp"
            android:backgroundTint="@color/spotify_green"
            android:text="@string/get_started"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Home Screen -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/homeLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <ImageButton
            android:id="@+id/backToWelcomeButton"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_margin="16dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/back_to_welcome"
            android:src="@android:drawable/ic_menu_revert"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:id="@+id/homeTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="60dp"
            android:text="@string/select_2_moods"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/backToWelcomeButton" />

        <GridLayout
            android:id="@+id/moodGrid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:layout_marginTop="32dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/homeTitle">

            <ToggleButton android:id="@+id/moodHappy" android:layout_width="160dp" android:layout_height="70dp" android:background="@drawable/mood_button_bg" android:textOff="@string/mood_happy" android:textOn="@string/mood_happy" android:textColor="@color/white" android:layout_margin="12dp" android:textSize="18sp" />
            <ToggleButton android:id="@+id/moodSad" android:layout_width="160dp" android:layout_height="70dp" android:background="@drawable/mood_button_bg" android:textOff="@string/mood_sad" android:textOn="@string/mood_sad" android:textColor="@color/white" android:layout_margin="12dp" android:textSize="18sp" />
            <ToggleButton android:id="@+id/moodAngry" android:layout_width="160dp" android:layout_height="70dp" android:background="@drawable/mood_button_bg" android:textOff="@string/mood_angry" android:textOn="@string/mood_angry" android:textColor="@color/white" android:layout_margin="12dp" android:textSize="18sp" />
            <ToggleButton android:id="@+id/moodEmotional" android:layout_width="160dp" android:layout_height="70dp" android:background="@drawable/mood_button_bg" android:textOff="@string/mood_emotional" android:textOn="@string/mood_emotional" android:textColor="@color/white" android:layout_margin="12dp" android:textSize="18sp" />
            <ToggleButton android:id="@+id/moodFrustrated" android:layout_width="160dp" android:layout_height="70dp" android:background="@drawable/mood_button_bg" android:textOff="@string/mood_frustrated" android:textOn="@string/mood_frustrated" android:textColor="@color/white" android:layout_margin="12dp" android:textSize="18sp" />
            <ToggleButton android:id="@+id/moodExcited" android:layout_width="160dp" android:layout_height="70dp" android:background="@drawable/mood_button_bg" android:textOff="@string/mood_excited" android:textOn="@string/mood_excited" android:textColor="@color/white" android:layout_margin="12dp" android:textSize="18sp" />

        </GridLayout>

        <LinearLayout
            android:id="@+id/buttonContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/moodGrid"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent">

            <Button
                android:id="@+id/myMoodMusicButton"
                android:layout_width="200dp"
                android:layout_height="56dp"
                android:backgroundTint="@color/spotify_green"
                android:text="@string/my_mood_music"
                android:textColor="@color/black"
                android:textStyle="bold" />

            <Button
                android:id="@+id/resetButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:backgroundTint="#80000000"
                android:text="@string/reset_moods"
                android:textColor="@color/white"
                style="@style/Widget.Material3.Button.TextButton" />
        </LinearLayout>

        <!-- Music Player Section (Spotify-like) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/musicPlayerLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#E6121212"
            app:cardCornerRadius="24dp"
            app:cardElevation="12dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp"
                android:gravity="center">

                <TextView
                    android:id="@+id/nowPlayingText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your Vibe Found 🎵"
                    android:textColor="@color/spotify_green"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/songDetailText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Song Title - Artist"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:layout_marginBottom="16dp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/replayButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/replay"
                        android:src="@android:drawable/ic_menu_revert"
                        app:tint="@color/white" />

                    <ImageButton
                        android:id="@+id/playPauseButton"
                        android:layout_width="72dp"
                        android:layout_height="72dp"
                        android:layout_marginHorizontal="32dp"
                        android:background="@drawable/mood_button_bg"
                        android:contentDescription="@string/play"
                        android:src="@android:drawable/ic_media_play"
                        app:tint="@color/white" />

                    <ImageButton
                        android:id="@+id/muteButton"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="?attr/selectableItemBackgroundBorderless"
                        android:contentDescription="@string/mute"
                        android:src="@android:drawable/ic_lock_silent_mode_off"
                        app:tint="@color/white" />

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Animated Info Overlay -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/infoOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2000000"
        android:visibility="gone"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="@string/info_description"
            android:scaleType="centerCrop"
            android:src="@drawable/aura_flow_bg"
            android:alpha="0.5" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="32dp"
            android:gravity="center"
            android:orientation="vertical"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/info_title"
                android:textColor="@color/spotify_green"
                android:textSize="44sp"
                android:textStyle="bold"
                android:layout_marginBottom="32dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="@string/info_message"
                android:textColor="@color/white"
                android:textSize="26sp"
                android:lineSpacingExtra="10dp"
                android:textStyle="italic" />

            <Button
                android:id="@+id/closeInfoButton"
                android:layout_width="200dp"
                android:layout_height="60dp"
                android:layout_marginTop="64dp"
                android:backgroundTint="@color/spotify_green"
                android:text="@string/info_ok"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:textStyle="bold" />

        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>